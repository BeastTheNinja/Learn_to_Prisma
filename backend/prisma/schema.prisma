generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  role      Role
  createdAt DateTime @default(now())

  blogs Blog[]

  @@map("users")
}


model Blog {
    id        Int      @id @default(autoincrement())
    title     String
    content   String
    createdAt DateTime @default(now())

    authorId  Int
    author    User @relation(fields: [authorId], references: [id])
}

enum Role {
  USER
  ADMIN
}
